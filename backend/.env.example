# Copy to .env and fill in values
# cp .env.example .env

# Groq API — Whisper transcription (to detect speakers/timecodes)
# Free tier: 7200 requests/day, 2 hours audio/day
# Get key at: https://console.groq.com → API Keys
GROQ_API_KEY=

# ElevenLabs API — voice cloning (IVC) + speech-to-speech conversion (STS)
# Free tier: 10,000 chars/month + 3 IVC voice clones
# Starter $5/mo: 30,000 chars + unlimited IVC clones (recommended)
# Get key at: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# HuggingFace token — optional, for pyannote speaker diarization
# Get free token at: https://huggingface.co/settings/tokens
HF_TOKEN=
